{
  "name": "oauth2-oidc-provider",
  "version": "1.0.0",
  "description": "OAuth2 and OIDC provider implementation",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "node dist/index.js",
    "build": "tsc",
    "dev": "tsc-watch --onSuccess \"node dist/index.js\"",
    "lint": "biome check",
    "format": "biome format --write",
    "lint:fix": "biome check --write .",
    "generate:keys": "sh script/key-gen.sh",
    "prepare": "husky"
  },
  "author": "Soumen Mondal",
  "license": "ISC",
  "packageManager": "pnpm@10.33.2",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "http-status-codes": "^2.3.0",
    "mongoose": "^9.5.0",
    "node-jose": "^2.2.0",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/node-jose": "^1.1.13",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "tsc-watch": "^7.2.0"
  },
  "lint-staged": {
    "*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  }
}
